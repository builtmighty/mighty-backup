{
    "name": "builtmighty/site-backup",
    "description": "WordPress plugin for automated site backups to DigitalOcean Spaces",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.300",
        "woocommerce/action-scheduler": "^3.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test:local": "\"C:/Users/tyler/AppData/Roaming/Local/lightning-services/php-8.1.29+0/bin/win64/php.exe\" -c \"C:/Users/tyler/AppData/Roaming/Local/lightning-services/php-8.1.29+0/bin/win64/php.ini-development\" -d extension_dir=\"C:/Users/tyler/AppData/Roaming/Local/lightning-services/php-8.1.29+0/bin/win64/ext\" -d extension=mbstring -d extension=openssl vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1.0"
        }
    }
}
